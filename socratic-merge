#!/usr/bin/env python3
"""
socratic-merge reads docs/socratic.md and distributes tagged discoveries
into docs/<category>/index.md files in the current repository.

Valid category tags come from the existing docs/ folder structure.
Each immediate subdirectory under docs/ is a valid category.

Expected socratic.md format:

## <Topic>

### <YYYY-MM-DD HH:MM>

- [architecture] Some discovery about architecture.
- [api] Some discovery about API.
"""

from __future__ import annotations

import re
import sys
from collections import defaultdict
from pathlib import Path

DEFAULT_CATEGORY = "decisions"


def discover_categories(docs: Path) -> set[str]:
    """Return folder names directly under docs/ as valid categories."""
    if not docs.exists():
        return set()
    return {
        d.name
        for d in docs.iterdir()
        if d.is_dir() and not d.name.startswith(".")
    }


def ensure_default_category(docs: Path, categories: set[str]) -> set[str]:
    """Make sure the default category folder exists."""
    (docs / DEFAULT_CATEGORY).mkdir(parents=True, exist_ok=True)
    return categories | {DEFAULT_CATEGORY}


def detect_category(line: str, categories: set[str]) -> str:
    # Explicit tag like [category] or [[category]].
    m = re.search(r"\[\[?([a-z0-9_]+)\]?\]?", line, re.I)
    if m:
        cat = m.group(1).lower()
        if cat in categories:
            return cat

    # Keyword fallback: match discovered category names, longest first.
    low = line.lower()
    for cat in sorted(categories, key=len, reverse=True):
        if cat.lower() in low:
            return cat

    if DEFAULT_CATEGORY in categories:
        return DEFAULT_CATEGORY
    return next(iter(categories))


def strip_category_tag(line: str) -> str:
    line = re.sub(r"\[\[?[a-z0-9_]+\]?\]?\s*", "", line, count=1, flags=re.I)
    line = re.sub(r"^[-*]\s*", "", line)
    return line.strip()


def load_socratic(path: Path) -> str:
    if not path.exists():
        print(f"Missing {path}", file=sys.stderr)
        sys.exit(1)
    return path.read_text(encoding="utf-8")


def parse_entries(text: str, categories: set[str]) -> list[dict]:
    entries = []
    # Split on H2 headings.
    parts = re.split(r"^(## .+)$", text, flags=re.M)
    if len(parts) < 3:
        return entries

    for i in range(1, len(parts), 2):
        heading = parts[i].strip()
        body = parts[i + 1] if i + 1 < len(parts) else ""
        topic = heading.lstrip("# ").strip()
        dt_match = re.search(r"^### (.+)$", body, re.M)
        dt = dt_match.group(1).strip() if dt_match else ""

        categorized: dict[str, list[str]] = defaultdict(list)
        for line in body.splitlines():
            if line.startswith("- ") or line.startswith("* "):
                cat = detect_category(line, categories)
                cleaned = strip_category_tag(line)
                if cleaned:
                    categorized[cat].append(cleaned)

        for cat, bullets in categorized.items():
            entries.append(
                {
                    "topic": topic,
                    "dt": dt,
                    "category": cat,
                    "bullets": bullets,
                }
            )

    return entries


def write_index(docs: Path, category: str, entries: list[dict]) -> None:
    folder = docs / category
    folder.mkdir(parents=True, exist_ok=True)
    index = folder / "index.md"

    with index.open("a", encoding="utf-8") as f:
        for entry in entries:
            f.write(f"## {entry['topic']}\n\n")
            if entry["dt"]:
                f.write(f"*{entry['dt']}*\n\n")
            for bullet in entry["bullets"]:
                f.write(f"- {bullet}\n")
            f.write("\n")


def main() -> int:
    root = Path.cwd()
    docs = root / "docs"
    socratic = docs / "socratic.md"
    text = load_socratic(socratic)

    categories = ensure_default_category(docs, discover_categories(docs))
    entries = parse_entries(text, categories)
    if not entries:
        print("No tagged discoveries found in docs/socratic.md")
        return 0

    grouped: dict[str, list[dict]] = defaultdict(list)
    for entry in entries:
        grouped[entry["category"]].append(entry)

    for category, group in grouped.items():
        write_index(docs, category, group)

    categories = ", ".join(sorted(grouped.keys()))
    print(
        f"Merged {len(entries)} tagged block(s) into {len(grouped)} category index file(s): {categories}"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
